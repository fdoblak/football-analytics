{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://football-analytics.local/schemas/perception/detection_run_receipt.schema.json",
  "title": "Detection run receipt (Stage 5A)",
  "description": "Execution receipt for a detection contract run. Contracts/metadata only — no inference required. Do not invent model SHA when unavailable.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "receipt_id",
    "run_id",
    "detector_id",
    "model_registry_id",
    "model_sha256",
    "adapter_id",
    "adapter_version",
    "config_fingerprint",
    "taxonomy_version",
    "source_video_ref",
    "frames_ref",
    "analysis_windows_ref",
    "eligible_frame_count",
    "processed_frame_count",
    "skipped_frame_count",
    "failed_frame_count",
    "processed_no_detection_count",
    "total_detection_count",
    "human_detection_count",
    "ball_detection_count",
    "pre_nms_count",
    "post_nms_count",
    "started_at_utc",
    "completed_at_utc",
    "status",
    "warnings",
    "errors",
    "artifacts",
    "environment_ref",
    "provenance"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "receipt_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$" },
    "run_id": { "type": "string", "minLength": 8 },
    "detector_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$" },
    "model_registry_id": { "type": ["string", "null"], "minLength": 1 },
    "model_sha256": {
      "type": ["string", "null"],
      "pattern": "^[a-f0-9]{64}$"
    },
    "adapter_id": { "type": "string", "minLength": 1 },
    "adapter_version": { "type": "string", "minLength": 1 },
    "config_fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "taxonomy_version": { "type": "string", "minLength": 1 },
    "source_video_ref": { "type": "string", "minLength": 1 },
    "frames_ref": { "type": "string", "minLength": 1 },
    "analysis_windows_ref": { "type": ["string", "null"], "minLength": 1 },
    "eligible_frame_count": { "type": "integer", "minimum": 0 },
    "processed_frame_count": { "type": "integer", "minimum": 0 },
    "skipped_frame_count": { "type": "integer", "minimum": 0 },
    "failed_frame_count": { "type": "integer", "minimum": 0 },
    "processed_no_detection_count": { "type": "integer", "minimum": 0 },
    "total_detection_count": { "type": "integer", "minimum": 0 },
    "human_detection_count": { "type": "integer", "minimum": 0 },
    "ball_detection_count": { "type": "integer", "minimum": 0 },
    "pre_nms_count": { "type": ["integer", "null"], "minimum": 0 },
    "post_nms_count": { "type": ["integer", "null"], "minimum": 0 },
    "started_at_utc": { "type": "string", "minLength": 20 },
    "completed_at_utc": { "type": "string", "minLength": 20 },
    "status": {
      "type": "string",
      "enum": ["succeeded", "rejected", "failed", "partial"]
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string", "minLength": 1 },
          "message": { "type": "string", "minLength": 1 }
        }
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string", "minLength": 1 },
          "message": { "type": "string", "minLength": 1 }
        }
      }
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": { "type": ["string", "null"] }
    },
    "environment_ref": { "type": ["string", "null"], "minLength": 1 },
    "execution_provider": { "type": ["string", "null"], "minLength": 1 },
    "precision": {
      "type": ["string", "null"],
      "enum": ["fp32", "fp16", null]
    },
    "software_versions": {
      "type": ["object", "null"],
      "additionalProperties": { "type": "string" }
    },
    "transform_fingerprint": {
      "type": ["string", "null"],
      "pattern": "^[a-f0-9]{64}$"
    },
    "threshold_config_fingerprint": {
      "type": ["string", "null"],
      "pattern": "^[a-f0-9]{64}$"
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage", "label"],
      "properties": {
        "stage": { "type": "string", "const": "5A" },
        "label": { "type": "string", "minLength": 1 },
        "notes": { "type": ["string", "null"] }
      }
    }
  }
}
