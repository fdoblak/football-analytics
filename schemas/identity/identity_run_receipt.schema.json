{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://football-analytics.local/schemas/identity/identity_run_receipt.schema.json",
  "title": "Identity run receipt (Stage 7A)",
  "description": "Receipt for identity contract fixtures / future identity runs. Stage 7A produces synthetic contract receipts only — no ReID inference, no auto target selection, no face/biometric identity.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "receipt_id",
    "run_id",
    "video_id",
    "request_id",
    "target_player_request_ref",
    "tracking_bundle_ref",
    "config_fingerprint",
    "policy_fingerprint",
    "assignment_counts",
    "evidence_counts",
    "link_counts",
    "target_coverage",
    "conflict_count",
    "review_required_count",
    "metric_eligible_track_count",
    "metric_eligible_frame_count",
    "ground_truth_evaluation_status",
    "output_artifacts",
    "started_at_utc",
    "completed_at_utc",
    "status",
    "warnings",
    "errors",
    "provenance"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "receipt_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$" },
    "run_id": { "type": "string", "minLength": 8 },
    "video_id": { "type": "string", "minLength": 1 },
    "request_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$" },
    "target_player_request_ref": { "type": "string", "minLength": 1 },
    "tracking_bundle_ref": { "type": "string", "minLength": 1 },
    "team_assignments_ref": { "type": ["string", "null"] },
    "jersey_observations_ref": { "type": ["string", "null"] },
    "appearance_evidence_ref": { "type": ["string", "null"] },
    "config_fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "policy_fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "assignment_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate",
        "provisional",
        "confirmed",
        "rejected",
        "revoked",
        "unknown",
        "total"
      ],
      "properties": {
        "candidate": { "type": "integer", "minimum": 0 },
        "provisional": { "type": "integer", "minimum": 0 },
        "confirmed": { "type": "integer", "minimum": 0 },
        "rejected": { "type": "integer", "minimum": 0 },
        "revoked": { "type": "integer", "minimum": 0 },
        "unknown": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 0 }
      }
    },
    "evidence_counts": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "link_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["candidate", "accepted", "rejected", "review_required", "unknown", "total"],
      "properties": {
        "candidate": { "type": "integer", "minimum": 0 },
        "accepted": { "type": "integer", "minimum": 0 },
        "rejected": { "type": "integer", "minimum": 0 },
        "review_required": { "type": "integer", "minimum": 0 },
        "unknown": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 0 }
      }
    },
    "target_coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["confirmed_frame_count", "provisional_frame_count", "unknown_frame_count"],
      "properties": {
        "confirmed_frame_count": { "type": "integer", "minimum": 0 },
        "provisional_frame_count": { "type": "integer", "minimum": 0 },
        "unknown_frame_count": { "type": "integer", "minimum": 0 }
      }
    },
    "conflict_count": { "type": "integer", "minimum": 0 },
    "review_required_count": { "type": "integer", "minimum": 0 },
    "metric_eligible_track_count": { "type": "integer", "minimum": 0 },
    "metric_eligible_frame_count": { "type": "integer", "minimum": 0 },
    "ground_truth_evaluation_status": { "type": "string", "minLength": 1 },
    "output_artifacts": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "size_bytes"],
        "properties": {
          "path": { "type": "string" },
          "sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
          "size_bytes": { "type": ["integer", "null"], "minimum": 0 }
        }
      }
    },
    "started_at_utc": { "type": "string", "minLength": 10 },
    "completed_at_utc": { "type": "string", "minLength": 10 },
    "status": {
      "type": "string",
      "enum": ["succeeded", "rejected", "failed", "partial"]
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage", "label", "face_biometric_forbidden", "no_auto_target_selection"],
      "properties": {
        "stage": { "type": "string", "const": "7A" },
        "label": { "type": "string", "minLength": 1 },
        "face_biometric_forbidden": { "type": "boolean", "const": true },
        "no_auto_target_selection": { "type": "boolean", "const": true },
        "no_track_merge": { "type": "boolean", "const": true },
        "notes": { "type": ["string", "null"] }
      }
    }
  }
}
