{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://football-analytics.local/schemas/identity/target_fusion_receipt.schema.json",
  "title": "Target identity fusion receipt (Stage 7E)",
  "description": "Receipt/quality for target evidence fusion + manual approval. Counts must recount from canonical artifacts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "receipt_id",
    "run_id",
    "video_id",
    "request_id",
    "config_fingerprint",
    "policy_fingerprint",
    "assignment_counts",
    "evidence_counts",
    "candidate_count",
    "manual_review_count",
    "manual_decision_count",
    "conflict_count",
    "false_overlap_count",
    "stale_decision_count",
    "metric_eligibility_summary",
    "audit_chain_valid",
    "ground_truth_evaluation_status",
    "output_artifacts",
    "started_at_utc",
    "completed_at_utc",
    "status",
    "warnings",
    "errors",
    "provenance"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "receipt_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$" },
    "run_id": { "type": "string", "minLength": 8 },
    "video_id": { "type": "string", "minLength": 1 },
    "request_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$" },
    "config_fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "policy_fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "tracking_fingerprint": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
    "appearance_fingerprint": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
    "team_fingerprint": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
    "jersey_fingerprint": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
    "assignment_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "candidate",
        "provisional",
        "confirmed",
        "rejected",
        "revoked",
        "unknown",
        "total"
      ],
      "properties": {
        "candidate": { "type": "integer", "minimum": 0 },
        "provisional": { "type": "integer", "minimum": 0 },
        "confirmed": { "type": "integer", "minimum": 0 },
        "rejected": { "type": "integer", "minimum": 0 },
        "revoked": { "type": "integer", "minimum": 0 },
        "unknown": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 0 }
      }
    },
    "evidence_counts": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "candidate_count": { "type": "integer", "minimum": 0 },
    "manual_review_count": { "type": "integer", "minimum": 0 },
    "manual_decision_count": { "type": "integer", "minimum": 0 },
    "supporting_evidence_total": { "type": "integer", "minimum": 0 },
    "conflicting_evidence_total": { "type": "integer", "minimum": 0 },
    "confirmed_observed_coverage_frames": { "type": "integer", "minimum": 0 },
    "conflict_count": { "type": "integer", "minimum": 0 },
    "false_overlap_count": { "type": "integer", "minimum": 0 },
    "stale_decision_count": { "type": "integer", "minimum": 0 },
    "metric_eligibility_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "eligible_frame_count",
        "provisional_only_frame_count",
        "not_eligible_frame_count",
        "not_evaluable_frame_count"
      ],
      "properties": {
        "eligible_frame_count": { "type": "integer", "minimum": 0 },
        "provisional_only_frame_count": { "type": "integer", "minimum": 0 },
        "not_eligible_frame_count": { "type": "integer", "minimum": 0 },
        "not_evaluable_frame_count": { "type": "integer", "minimum": 0 }
      }
    },
    "audit_chain_valid": { "type": "boolean" },
    "ground_truth_evaluation_status": { "type": "string", "minLength": 1 },
    "output_artifacts": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "size_bytes"],
        "properties": {
          "path": { "type": "string" },
          "sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
          "size_bytes": { "type": ["integer", "null"], "minimum": 0 }
        }
      }
    },
    "started_at_utc": { "type": "string", "minLength": 10 },
    "completed_at_utc": { "type": "string", "minLength": 10 },
    "status": {
      "type": "string",
      "enum": ["succeeded", "rejected", "failed", "partial"]
    },
    "warnings": { "type": "array", "items": { "type": "string" } },
    "errors": { "type": "array", "items": { "type": "string" } },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stage",
        "face_biometric_forbidden",
        "auto_confirm_forbidden",
        "no_track_merge",
        "cross_video_auto_link_forbidden"
      ],
      "properties": {
        "stage": { "type": "string", "const": "7E" },
        "face_biometric_forbidden": { "type": "boolean", "const": true },
        "auto_confirm_forbidden": { "type": "boolean", "const": true },
        "no_track_merge": { "type": "boolean", "const": true },
        "cross_video_auto_link_forbidden": { "type": "boolean", "const": true },
        "notes": { "type": ["string", "null"] }
      }
    }
  }
}
