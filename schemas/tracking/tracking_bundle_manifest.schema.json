{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://football-analytics.local/schemas/tracking/tracking_bundle_manifest.schema.json",
  "title": "Tracking bundle manifest (Stage 6D)",
  "description": "Minimal versioned manifest for fused tracking artifacts. Track IDs are not identities.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "video_id",
    "pipeline_id",
    "pipeline_version",
    "config_fingerprint",
    "artifacts",
    "created_at_utc"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "run_id": { "type": "string", "minLength": 8 },
    "video_id": { "type": "string", "minLength": 1 },
    "pipeline_id": { "type": "string", "minLength": 1 },
    "pipeline_version": { "type": "string", "minLength": 1 },
    "config_fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "source_video_sha256": {
      "type": ["string", "null"],
      "pattern": "^[a-f0-9]{64}$"
    },
    "timeline_fingerprint": {
      "type": ["string", "null"],
      "pattern": "^[a-f0-9]{64}$"
    },
    "detection_bundle_fingerprint": {
      "type": ["string", "null"],
      "pattern": "^[a-f0-9]{64}$"
    },
    "analysis_window_fingerprint": {
      "type": ["string", "null"],
      "pattern": "^[a-f0-9]{64}$"
    },
    "artifacts": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true,
        "required": ["path", "sha256", "size_bytes"],
        "properties": {
          "path": { "type": "string" },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "size_bytes": { "type": "integer", "minimum": 0 }
        }
      }
    },
    "created_at_utc": { "type": "string", "minLength": 20 }
  }
}
