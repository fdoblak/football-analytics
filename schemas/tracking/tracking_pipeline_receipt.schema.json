{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://football-analytics.local/schemas/tracking/tracking_pipeline_receipt.schema.json",
  "title": "Tracking pipeline receipt (Stage 6D)",
  "description": "Fusion pipeline receipt for human+ball tracking bundle. Operational provenance only — not football tracking accuracy. Track IDs are not player identities.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "receipt_id",
    "run_id",
    "video_id",
    "pipeline_id",
    "pipeline_version",
    "config_fingerprint",
    "source_video_sha256",
    "timeline_fingerprint",
    "detection_bundle_fingerprint",
    "started_at_utc",
    "completed_at_utc",
    "status",
    "quality_gate_status",
    "ground_truth_evaluation_status",
    "human_track_count",
    "ball_track_count",
    "total_track_count",
    "observed_count",
    "predicted_count",
    "interpolated_count",
    "review_required_count",
    "inputs",
    "outputs",
    "output_hashes",
    "warnings",
    "errors",
    "provenance"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "receipt_id": { "type": "string", "minLength": 4 },
    "run_id": { "type": "string", "minLength": 8 },
    "video_id": { "type": "string", "minLength": 1 },
    "pipeline_id": { "type": "string", "minLength": 1 },
    "pipeline_version": { "type": "string", "minLength": 1 },
    "config_fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "source_video_sha256": {
      "type": ["string", "null"],
      "pattern": "^[a-f0-9]{64}$"
    },
    "timeline_fingerprint": {
      "type": ["string", "null"],
      "pattern": "^[a-f0-9]{64}$"
    },
    "detection_bundle_fingerprint": {
      "type": ["string", "null"],
      "pattern": "^[a-f0-9]{64}$"
    },
    "analysis_window_fingerprint": {
      "type": ["string", "null"],
      "pattern": "^[a-f0-9]{64}$"
    },
    "human_config_fingerprint": { "type": ["string", "null"] },
    "ball_config_fingerprint": { "type": ["string", "null"] },
    "detection_config_fingerprint": { "type": ["string", "null"] },
    "started_at_utc": { "type": "string", "minLength": 20 },
    "completed_at_utc": { "type": "string", "minLength": 20 },
    "status": {
      "type": "string",
      "enum": ["succeeded", "rejected", "failed", "partial"]
    },
    "quality_gate_status": {
      "type": "string",
      "enum": ["pass", "pass_with_findings", "fail", "not_evaluated"]
    },
    "ground_truth_evaluation_status": { "type": "string", "minLength": 1 },
    "human_input_detection_count": { "type": "integer", "minimum": 0 },
    "ball_input_detection_count": { "type": "integer", "minimum": 0 },
    "assigned_detection_count": { "type": "integer", "minimum": 0 },
    "unassigned_detection_count": { "type": "integer", "minimum": 0 },
    "human_track_count": { "type": "integer", "minimum": 0 },
    "ball_track_count": { "type": "integer", "minimum": 0 },
    "total_track_count": { "type": "integer", "minimum": 0 },
    "tentative_count": { "type": "integer", "minimum": 0 },
    "confirmed_count": { "type": "integer", "minimum": 0 },
    "lost_count": { "type": "integer", "minimum": 0 },
    "terminated_count": { "type": "integer", "minimum": 0 },
    "observed_count": { "type": "integer", "minimum": 0 },
    "predicted_count": { "type": "integer", "minimum": 0 },
    "interpolated_count": { "type": "integer", "minimum": 0 },
    "fragmentation_count": { "type": "integer", "minimum": 0 },
    "recovery_count": { "type": "integer", "minimum": 0 },
    "cross_cut_violation_count": { "type": "integer", "minimum": 0 },
    "invalid_fk_count": { "type": "integer", "minimum": 0 },
    "duplicate_count": { "type": "integer", "minimum": 0 },
    "role_abstention_count": { "type": "integer", "minimum": 0 },
    "review_required_count": { "type": "integer", "minimum": 0 },
    "primary_ball_frames": { "type": "integer", "minimum": 0 },
    "ambiguous_ball_frames": { "type": "integer", "minimum": 0 },
    "no_candidate_ball_frames": { "type": "integer", "minimum": 0 },
    "inputs": {
      "type": "object",
      "additionalProperties": { "type": ["string", "null", "object"] }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": { "type": ["string", "null"] }
    },
    "output_hashes": {
      "type": "object",
      "additionalProperties": { "type": ["string", "null"] }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" }
        }
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string" },
          "message": { "type": "string" }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": true,
      "required": ["stage", "label"],
      "properties": {
        "stage": { "type": "string", "const": "6D" },
        "label": { "type": "string", "minLength": 1 }
      }
    }
  }
}
