{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://football-analytics.local/schemas/tracking/tracking_run_receipt.schema.json",
  "title": "Tracking run receipt (Stage 6A)",
  "description": "Execution receipt for a tracking contract run. Stage 6A produces synthetic contract receipts only — no real tracker inference.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "receipt_id",
    "run_id",
    "video_id",
    "request_id",
    "tracker_id",
    "tracker_version",
    "config_fingerprint",
    "policy_fingerprint",
    "input_artifacts",
    "output_artifacts",
    "total_input_detections",
    "detections_used",
    "detections_rejected",
    "unassigned_detection_count",
    "track_counts",
    "observation_counts",
    "invalid_transition_count",
    "invalid_fk_count",
    "duplicate_count",
    "routing_gap_count",
    "review_required_count",
    "ground_truth_evaluation_status",
    "started_at_utc",
    "completed_at_utc",
    "status",
    "warnings",
    "errors",
    "provenance"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "receipt_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$" },
    "run_id": { "type": "string", "minLength": 8 },
    "video_id": { "type": "string", "minLength": 1 },
    "request_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$" },
    "tracker_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$" },
    "tracker_version": { "type": "string", "minLength": 1 },
    "config_fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "policy_fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "input_artifacts": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "size_bytes"],
        "properties": {
          "path": { "type": "string" },
          "sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
          "size_bytes": { "type": ["integer", "null"], "minimum": 0 }
        }
      }
    },
    "output_artifacts": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": ["path", "sha256", "size_bytes"],
        "properties": {
          "path": { "type": "string" },
          "sha256": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
          "size_bytes": { "type": ["integer", "null"], "minimum": 0 }
        }
      }
    },
    "total_input_detections": { "type": "integer", "minimum": 0 },
    "detections_used": { "type": "integer", "minimum": 0 },
    "detections_rejected": { "type": "integer", "minimum": 0 },
    "unassigned_detection_count": { "type": "integer", "minimum": 0 },
    "track_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["tentative", "confirmed", "lost", "terminated"],
      "properties": {
        "tentative": { "type": "integer", "minimum": 0 },
        "confirmed": { "type": "integer", "minimum": 0 },
        "lost": { "type": "integer", "minimum": 0 },
        "terminated": { "type": "integer", "minimum": 0 }
      }
    },
    "observation_counts": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "detection_associated",
        "predicted",
        "interpolated",
        "observed",
        "total"
      ],
      "properties": {
        "detection_associated": { "type": "integer", "minimum": 0 },
        "predicted": { "type": "integer", "minimum": 0 },
        "interpolated": { "type": "integer", "minimum": 0 },
        "observed": { "type": "integer", "minimum": 0 },
        "total": { "type": "integer", "minimum": 0 }
      }
    },
    "invalid_transition_count": { "type": "integer", "minimum": 0 },
    "invalid_fk_count": { "type": "integer", "minimum": 0 },
    "duplicate_count": { "type": "integer", "minimum": 0 },
    "routing_gap_count": { "type": "integer", "minimum": 0 },
    "review_required_count": { "type": "integer", "minimum": 0 },
    "ground_truth_evaluation_status": {
      "type": "string",
      "enum": [
        "NOT_EVALUATED_NO_REVIEWED_TRACKING_GROUND_TRUTH",
        "NOT_EVALUATED_NO_REVIEWED_HUMAN_TRACKING_GROUND_TRUTH",
        "evaluated",
        "partial"
      ]
    },
    "started_at_utc": { "type": "string", "minLength": 20 },
    "completed_at_utc": { "type": "string", "minLength": 20 },
    "status": {
      "type": "string",
      "enum": ["succeeded", "rejected", "failed", "partial"]
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string", "minLength": 1 },
          "message": { "type": "string", "minLength": 1 }
        }
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string", "minLength": 1 },
          "message": { "type": "string", "minLength": 1 }
        }
      }
    },
    "environment_ref": { "type": ["string", "null"] },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage", "label"],
      "properties": {
        "stage": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "notes": { "type": ["string", "null"] },
        "tracker_algorithm": {
          "type": "string",
          "enum": [
            "none_stage_6a_contracts_only",
            "iou_constant_velocity_v1"
          ]
        },
        "merge_reid": { "type": "boolean", "const": false },
        "track_id_is_player_identity": { "type": "boolean", "const": false }
      }
    }
  }
}
