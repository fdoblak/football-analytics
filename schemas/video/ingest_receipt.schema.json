{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://football-analytics.local/schemas/video/ingest_receipt.schema.json",
  "title": "Video ingest receipt (Stage 3A)",
  "description": "Secret-safe contract-level receipt. Stage 3A must not claim production ingest success.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "receipt_id",
    "request_id",
    "run_id",
    "source_id",
    "source_sha256",
    "source_size_bytes",
    "status",
    "started_at_utc",
    "completed_at_utc",
    "probe_record_ref",
    "normalize_plan_ref",
    "artifact_refs",
    "policy_version",
    "contract_fingerprints",
    "warnings",
    "errors",
    "provenance"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "receipt_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$" },
    "request_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$" },
    "run_id": {
      "type": "string",
      "pattern": "^run_[0-9]{8}T[0-9]{12}Z_[a-f0-9]{12}$"
    },
    "source_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$" },
    "source_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "source_size_bytes": { "type": "integer", "minimum": 0 },
    "status": {
      "type": "string",
      "enum": ["planned", "validated", "rejected", "failed"],
      "description": "No succeeded/completed in Stage 3A — those require real ingest execution later."
    },
    "started_at_utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]{1,6})?Z$"
    },
    "completed_at_utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]{1,6})?Z$"
    },
    "probe_record_ref": { "type": ["string", "null"], "minLength": 1 },
    "normalize_plan_ref": { "type": ["string", "null"], "minLength": 1 },
    "artifact_refs": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "policy_version": { "type": "string", "minLength": 1 },
    "contract_fingerprints": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "request"],
      "properties": {
        "source": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "request": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
        "probe": { "type": ["string", "null"], "pattern": "^[a-f0-9]{64}$" },
        "normalize_plan": {
          "type": ["string", "null"],
          "pattern": "^[a-f0-9]{64}$"
        }
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string", "minLength": 1 },
          "message": { "type": "string" }
        }
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["code", "message"],
        "properties": {
          "code": { "type": "string", "minLength": 1 },
          "message": { "type": "string" }
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["stage", "label"],
      "properties": {
        "stage": { "type": "string", "const": "3A" },
        "label": { "type": "string", "minLength": 1 },
        "notes": { "type": ["string", "null"] }
      }
    }
  }
}
