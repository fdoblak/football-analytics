{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://football-analytics.local/schemas/video/video_source.schema.json",
  "title": "Video source (Stage 3A)",
  "description": "Immutable local video source identity. source_path is runtime-only; never embed real user paths in committed fixtures.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source_id",
    "source_kind",
    "original_filename",
    "source_path",
    "source_size_bytes",
    "source_sha256",
    "media_type",
    "container_hint",
    "created_at_utc",
    "registered_at_utc",
    "immutability_policy",
    "provenance"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "source_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{1,63}$"
    },
    "source_kind": {
      "type": "string",
      "enum": ["user_local_video", "synthetic_fixture", "project_fixture"]
    },
    "original_filename": {
      "type": "string",
      "minLength": 1,
      "maxLength": 255,
      "pattern": "^[^/\\\\]+$"
    },
    "source_path": {
      "type": "string",
      "minLength": 1,
      "description": "Absolute runtime path under an allowed root; validated at resolve time."
    },
    "source_size_bytes": { "type": "integer", "minimum": 0 },
    "source_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "media_type": { "type": "string", "minLength": 1 },
    "container_hint": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "created_at_utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]{1,6})?Z$"
    },
    "registered_at_utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]{1,6})?Z$"
    },
    "immutability_policy": {
      "type": "string",
      "enum": ["immutable_source", "detect_mutation"]
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["origin", "label"],
      "properties": {
        "origin": {
          "type": "string",
          "enum": ["local_file", "synthetic_generated", "project_fixture"]
        },
        "label": { "type": "string", "minLength": 1 },
        "notes": { "type": ["string", "null"] }
      }
    }
  }
}
