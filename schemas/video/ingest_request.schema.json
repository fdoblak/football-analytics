{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://football-analytics.local/schemas/video/ingest_request.schema.json",
  "title": "Video ingest request (Stage 3A)",
  "description": "Validated ingest request. Stage 3A validates the contract only; no copy/probe/normalize execution.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "request_id",
    "run_id",
    "source_id",
    "source_path",
    "requested_at_utc",
    "ingest_mode",
    "policy_version",
    "probe_requested",
    "normalization_requested",
    "expected_source_sha256",
    "expected_source_size_bytes",
    "output_root",
    "fixture_mode"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "request_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{1,63}$"
    },
    "run_id": {
      "type": "string",
      "pattern": "^run_[0-9]{8}T[0-9]{12}Z_[a-f0-9]{12}$"
    },
    "source_id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{1,63}$"
    },
    "source_path": { "type": "string", "minLength": 1 },
    "requested_at_utc": {
      "type": "string",
      "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}T[0-9]{2}:[0-9]{2}:[0-9]{2}(\\.[0-9]{1,6})?Z$"
    },
    "ingest_mode": {
      "type": "string",
      "enum": ["validate_only", "plan_only", "fixture_design"]
    },
    "policy_version": { "type": "string", "minLength": 1 },
    "probe_requested": { "type": "boolean" },
    "normalization_requested": { "type": "boolean" },
    "expected_source_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "expected_source_size_bytes": { "type": "integer", "minimum": 0 },
    "output_root": { "type": "string", "minLength": 1 },
    "fixture_mode": { "type": "boolean" }
  }
}
