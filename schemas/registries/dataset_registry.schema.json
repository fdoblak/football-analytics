{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://football-analytics.local/schemas/dataset_registry.schema.json",
  "title": "football-analytics dataset registry",
  "type": "object",
  "required": ["schema_version", "datasets"],
  "additionalProperties": true,
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "updated_at": { "type": ["string", "null"] },
    "notes": { "type": ["string", "null"] },
    "datasets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id", "display_name", "task", "status", "local_path", "source",
          "license_status", "access_level", "nda_required", "credentials_required",
          "planned_stage"
        ],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": ["planned", "not_downloaded", "available", "verified", "blocked_access", "deprecated"]
          },
          "access_level": {
            "type": "string",
            "enum": ["public", "registration_required", "nda_required", "restricted", "unknown"]
          },
          "license_status": {
            "type": "string",
            "enum": ["approved", "review_required", "restricted", "unknown", "prohibited"]
          },
          "local_path": { "type": ["string", "null"] },
          "checksum": { "type": ["string", "null"] },
          "size_bytes": { "type": ["integer", "null"], "minimum": 1 },
          "source_url": { "type": ["string", "null"] },
          "credentials": { "not": {} }
        }
      }
    }
  }
}
