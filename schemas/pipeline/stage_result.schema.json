{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://football-analytics.local/schemas/pipeline/stage_result.schema.json",
  "title": "Stage result (Stage 2D)",
  "description": "Single-stage outcome. Distinct from cache_manifest and run_manifest.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "stage_name",
    "stage_version",
    "status",
    "cache_key",
    "cache_hit",
    "started_at_utc",
    "finished_at_utc",
    "duration_ms",
    "inputs",
    "outputs",
    "metrics",
    "warnings",
    "error",
    "execution_fingerprint"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "run_id": {
      "type": "string",
      "pattern": "^run_[0-9]{8}T[0-9]{12}Z_[a-f0-9]{12}$"
    },
    "stage_name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{1,63}$"
    },
    "stage_version": { "type": "integer", "minimum": 1 },
    "status": {
      "type": "string",
      "enum": ["succeeded", "failed", "cache_hit", "skipped", "cancelled"]
    },
    "cache_key": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "cache_hit": { "type": "boolean" },
    "started_at_utc": { "type": "string", "minLength": 1 },
    "finished_at_utc": { "type": "string", "minLength": 1 },
    "duration_ms": { "type": "integer", "minimum": 0 },
    "inputs": {
      "type": "object",
      "additionalProperties": { "type": "object" }
    },
    "outputs": {
      "type": "object",
      "additionalProperties": { "type": "object" }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": {
        "type": ["string", "integer", "number", "boolean"]
      }
    },
    "warnings": {
      "type": "array",
      "items": { "type": "string" }
    },
    "error": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["class", "message"],
      "properties": {
        "class": { "type": "string", "minLength": 1 },
        "message": { "type": "string" }
      }
    },
    "execution_fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
