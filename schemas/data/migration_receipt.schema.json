{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://football-analytics.local/schemas/data/migration_receipt.schema.json",
  "title": "Schema migration receipt (Stage 2C)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "migration_id",
    "created_at_utc",
    "contract_name",
    "from_version",
    "to_version",
    "source_path",
    "destination_path",
    "source_file_sha256",
    "destination_file_sha256",
    "source_schema_fingerprint",
    "destination_schema_fingerprint",
    "source_row_count",
    "destination_row_count",
    "primary_key_preserved",
    "row_order_preserved",
    "lossy",
    "steps",
    "status",
    "tool_version"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "migration_id": { "type": "string", "minLength": 1 },
    "created_at_utc": { "type": "string", "minLength": 1 },
    "contract_name": { "type": "string", "minLength": 1 },
    "from_version": { "type": "integer", "minimum": 0 },
    "to_version": { "type": "integer", "minimum": 0 },
    "source_path": { "type": "string", "minLength": 1 },
    "destination_path": { "type": "string", "minLength": 1 },
    "source_file_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "destination_file_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "source_schema_fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "destination_schema_fingerprint": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "source_row_count": { "type": "integer", "minimum": 0 },
    "destination_row_count": { "type": "integer", "minimum": 0 },
    "primary_key_preserved": { "type": "boolean" },
    "row_order_preserved": { "type": "boolean" },
    "lossy": { "type": "boolean" },
    "steps": {
      "type": "array",
      "items": { "type": "string" }
    },
    "status": { "type": "string", "enum": ["success", "failed"] },
    "tool_version": { "type": "string", "minLength": 1 },
    "error": { "type": ["string", "null"] }
  }
}
