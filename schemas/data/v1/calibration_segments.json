{
  "contract_name": "calibration_segments",
  "version": 1,
  "description": "Stage 8A time-scoped calibration segments with image_to_pitch homography. Extends calibrations v1 without mutating it.",
  "fields": [
    {"name": "run_id", "type": "string", "nullable": false},
    {"name": "video_id", "type": "string", "nullable": false},
    {"name": "segment_id", "type": "string", "nullable": false},
    {"name": "calibration_id", "type": "int64", "nullable": false},
    {"name": "start_time_us", "type": "int64", "nullable": false},
    {"name": "end_time_us", "type": "int64", "nullable": false},
    {"name": "start_frame_index", "type": "int64", "nullable": false},
    {"name": "end_frame_index", "type": "int64", "nullable": true},
    {"name": "source_frame_index", "type": "int64", "nullable": false},
    {"name": "shot_segment_id", "type": "string", "nullable": true},
    {"name": "analysis_window_id", "type": "string", "nullable": true},
    {"name": "camera_view", "type": "string", "nullable": false},
    {"name": "camera_motion", "type": "string", "nullable": false},
    {"name": "validity_status", "type": "string", "nullable": false},
    {"name": "homography_image_to_pitch", "type": "fixed_size_list", "nullable": true, "value_type": "float64", "list_size": 9},
    {"name": "homography_pitch_to_image", "type": "fixed_size_list", "nullable": true, "value_type": "float64", "list_size": 9},
    {"name": "condition_number", "type": "float64", "nullable": true},
    {"name": "determinant", "type": "float64", "nullable": true},
    {"name": "correspondence_count", "type": "int32", "nullable": false},
    {"name": "inlier_count", "type": "int32", "nullable": false},
    {"name": "inlier_ratio", "type": "float32", "nullable": true},
    {"name": "mean_reprojection_error_px", "type": "float32", "nullable": true},
    {"name": "coverage_hull_area_fraction", "type": "float32", "nullable": true},
    {"name": "pitch_length_m", "type": "float32", "nullable": false},
    {"name": "pitch_width_m", "type": "float32", "nullable": false},
    {"name": "pitch_template_fingerprint", "type": "string", "nullable": false},
    {"name": "solver_method", "type": "string", "nullable": false},
    {"name": "solver_version", "type": "string", "nullable": false},
    {"name": "is_interpolated", "type": "bool", "nullable": false},
    {"name": "reuse_policy", "type": "string", "nullable": false},
    {"name": "boundary_reason", "type": "string", "nullable": false},
    {"name": "previous_segment_id", "type": "string", "nullable": true},
    {"name": "next_segment_id", "type": "string", "nullable": true},
    {"name": "physical_metric_eligible", "type": "bool", "nullable": false},
    {"name": "manual_review_required", "type": "bool", "nullable": false},
    {"name": "reason_codes", "type": "list", "nullable": false, "value_type": "string"},
    {"name": "quality_flags", "type": "list", "nullable": false, "value_type": "string"},
    {"name": "provenance_json", "type": "string", "nullable": true},
    {"name": "contract_version", "type": "int32", "nullable": false}
  ],
  "primary_key": ["run_id", "video_id", "segment_id"],
  "foreign_keys": [],
  "partition_by": ["run_id", "video_id"],
  "sort_by": ["run_id", "video_id", "start_time_us", "segment_id"],
  "semantic_rules": [
    {"id": "run_id_format", "rule": "run_id_stage2b"},
    {"id": "video_id_safe", "rule": "safe_identifier", "field": "video_id"},
    {"id": "segment_id_safe", "rule": "safe_identifier", "field": "segment_id"},
    {"id": "cal_id_ge0", "rule": "int_ge", "field": "calibration_id", "value": 0},
    {"id": "start_time_ge0", "rule": "int_ge", "field": "start_time_us", "value": 0},
    {"id": "end_time_ge0", "rule": "int_ge", "field": "end_time_us", "value": 0},
    {"id": "start_frame_ge0", "rule": "int_ge", "field": "start_frame_index", "value": 0},
    {"id": "source_frame_ge0", "rule": "int_ge", "field": "source_frame_index", "value": 0},
    {"id": "end_frame_ge0_or_null", "rule": "int_ge_or_null", "field": "end_frame_index", "value": 0},
    {
      "id": "camera_view_enum",
      "rule": "enum",
      "field": "camera_view",
      "values": ["main", "closeup", "tactical", "replay", "unknown"]
    },
    {
      "id": "camera_motion_enum",
      "rule": "enum",
      "field": "camera_motion",
      "values": ["static", "pan", "zoom", "pan_zoom", "unknown"]
    },
    {
      "id": "validity_enum",
      "rule": "enum",
      "field": "validity_status",
      "values": ["valid", "invalid", "uncertain", "not_eligible", "conflict", "abstain"]
    },
    {
      "id": "reuse_enum",
      "rule": "enum",
      "field": "reuse_policy",
      "values": ["none", "hold", "interpolate_forbidden", "review"]
    },
    {"id": "corr_ge0", "rule": "int_ge", "field": "correspondence_count", "value": 0},
    {"id": "inlier_ge0", "rule": "int_ge", "field": "inlier_count", "value": 0},
    {"id": "inlier_ratio_or_null", "rule": "float_unit_interval_or_null", "field": "inlier_ratio"},
    {"id": "reproj_ge0_or_null", "rule": "float_ge_or_null", "field": "mean_reprojection_error_px", "value": 0},
    {"id": "coverage_or_null", "rule": "float_unit_interval_or_null", "field": "coverage_hull_area_fraction"},
    {"id": "pitch_positive", "rule": "float_gt", "fields": ["pitch_length_m", "pitch_width_m"], "value": 0},
    {"id": "H_finite", "rule": "fixed_list_finite_or_null", "field": "homography_image_to_pitch"},
    {"id": "Hinv_finite", "rule": "fixed_list_finite_or_null", "field": "homography_pitch_to_image"},
    {"id": "reason_no_null", "rule": "list_no_null_items", "field": "reason_codes"},
    {"id": "quality_no_null", "rule": "list_no_null_items", "field": "quality_flags"},
    {"id": "contract_version_ge1", "rule": "int_ge", "field": "contract_version", "value": 1}
  ],
  "table_metadata": {
    "homography_layout": "row_major_3x3",
    "homography_maps": "image_to_pitch",
    "interval": "half_open_start_end_us",
    "stage": "8A"
  }
}
