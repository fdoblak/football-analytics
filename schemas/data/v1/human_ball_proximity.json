    {"name": "ball_observation_state", "type": "string", "nullable": false},
    {"name": "evidence_space", "type": "string", "nullable": false},
    {"name": "ball_air_state", "type": "string", "nullable": false},
    {"name": "ball_candidate_status", "type": "string", "nullable": false},
    {"name": "calibration_status", "type": "string", "nullable": false},
    {"name": "playability_status", "type": "string", "nullable": false},
    {"name": "target_relationship", "type": "string", "nullable": false},
    {"name": "evidence_level", "type": "string", "nullable": false},
    {"name": "is_nearest_human", "type": "bool", "nullable": false},
    {"name": "nearest_implies_possession", "type": "bool", "nullable": false},
    {"name": "pitch_distance_usable", "type": "bool", "nullable": false},
    {"name": "uncertainty", "type": "float32", "nullable": true},
    {"name": "eligibility_status", "type": "string", "nullable": false},
    {"name": "human_observation_id", "type": "string", "nullable": true},
    {"name": "ball_observation_id", "type": "string", "nullable": true},
