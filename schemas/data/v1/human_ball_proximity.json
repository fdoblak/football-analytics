    {"id": "ball_ref_enum", "rule": "enum", "field": "ball_reference_type", "values": ["detection_centre", "projected_ground", "unknown"]},
    {"id": "human_obs_enum", "rule": "enum", "field": "human_observation_state", "values": ["observed", "predicted", "interpolated", "missing"]},
    {"id": "ball_obs_enum", "rule": "enum", "field": "ball_observation_state", "values": ["observed", "predicted", "interpolated", "missing"]},
    {"id": "evidence_space_enum", "rule": "enum", "field": "evidence_space", "values": ["image", "pitch", "both", "none"]},
    {"id": "ball_air_enum", "rule": "enum", "field": "ball_air_state", "values": ["grounded", "airborne", "unknown"]},
    {"id": "ball_cand_enum", "rule": "enum", "field": "ball_candidate_status", "values": ["primary", "ambiguous", "missing", "rejected"]},
    {"id": "cal_enum", "rule": "enum", "field": "calibration_status", "values": ["valid", "invalid", "unknown"]},
    {"id": "play_enum", "rule": "enum", "field": "playability_status", "values": ["playable", "replay", "non_playable", "unknown"]},
    {"id": "target_rel_enum", "rule": "enum", "field": "target_relationship", "values": ["confirmed_target", "candidate_target", "non_target", "anonymous", "unknown"]},
    {"id": "evidence_level_enum", "rule": "enum", "field": "evidence_level", "values": ["candidate", "provisional", "confirmed", "contested", "unknown", "not_evaluable", "rejected"]},
    {"id": "elig_enum", "rule": "enum", "field": "eligibility_status", "values": ["eligible", "ineligible", "not_evaluable", "excluded"]},
    {"id": "reason_no_null", "rule": "list_no_null_items", "field": "reason_codes"},
    {"id": "quality_no_null", "rule": "list_no_null_items", "field": "quality_flags"},
    {"id": "contract_version_ge1", "rule": "int_ge", "field": "contract_version", "value": 1}
  ],
  "table_metadata": {
    "stage": "10A",
    "nearest_player_is_not_possession": "true",
    "proximity_is_not_contact": "true",
    "proximity_is_not_event": "true",
    "time_base": "video_time_us"
  }
