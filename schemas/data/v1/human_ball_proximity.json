  "primary_key": ["run_id", "video_id", "proximity_id"],
  "foreign_keys": [],
  "partition_by": ["run_id", "video_id"],
  "sort_by": ["run_id", "video_id", "video_time_us", "proximity_id"],
  "semantic_rules": [
    {"id": "run_id_format", "rule": "run_id_stage2b"},
    {"id": "video_id_safe", "rule": "safe_identifier", "field": "video_id"},
    {"id": "proximity_safe", "rule": "safe_identifier", "field": "proximity_id"},
    {"id": "human_track_ge0", "rule": "int_ge", "field": "human_track_id", "value": 0},
    {"id": "ball_track_ge0_or_null", "rule": "int_ge_or_null", "field": "ball_track_id", "value": 0},
    {"id": "frame_ge0", "rule": "int_ge", "field": "frame_index", "value": 0},
    {"id": "time_ge0", "rule": "int_ge", "field": "video_time_us", "value": 0},
