      "nullable": false
    },
    {
      "name": "video_id",
      "type": "string",
      "nullable": false
    },
    {
      "name": "frame_index",
      "type": "int64",
      "nullable": false
    },
    {
      "name": "observation_id",
      "type": "int64",
      "nullable": false
    },
    {
      "name": "track_id",
      "type": "int64",
      "nullable": false
    },
    {
      "name": "raw_text",
      "type": "string",
      "nullable": true
    },
    {
      "name": "normalized_number",
      "type": "int16",
      "nullable": true
    },
    {
      "name": "digit_count",
