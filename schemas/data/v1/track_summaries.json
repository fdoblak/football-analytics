{
  "contract_name": "track_summaries",
  "version": 1,
  "description": "Track-level aggregates over observations.",
  "fields": [
    {
      "name": "run_id",
      "type": "string",
      "nullable": false
    },
    {
      "name": "video_id",
      "type": "string",
      "nullable": false
    },
    {
      "name": "track_id",
      "type": "int64",
      "nullable": false
    },
    {
      "name": "class_id",
      "type": "int16",
      "nullable": false
    },
    {
      "name": "first_frame_index",
      "type": "int64",
      "nullable": false
    },
    {
      "name": "last_frame_index",
      "type": "int64",
      "nullable": false
    },
    {
      "name": "observation_count",
      "type": "int64",
      "nullable": false
    },
    {
      "name": "observed_count",
      "type": "int64",
      "nullable": false
    },
    {
      "name": "predicted_count",
      "type": "int64",
      "nullable": false
    },
    {
      "name": "mean_confidence",
      "type": "float32",
      "nullable": true
    },
    {
      "name": "max_confidence",
      "type": "float32",
      "nullable": true
    },
    {
      "name": "termination_reason",
      "type": "string",
      "nullable": false
    },
    {
      "name": "quality_flags",
      "type": "list",
      "nullable": false,
      "value_type": "string"
    }
  ],
  "primary_key": [
    "run_id",
    "video_id",
    "track_id"
  ],
  "foreign_keys": [],
  "partition_by": [
    "run_id",
    "video_id"
  ],
  "sort_by": [
    "run_id",
    "video_id",
    "track_id"
  ],
  "semantic_rules": [
    {
      "id": "run_id_format",
      "rule": "run_id_stage2b"
    },
    {
      "id": "video_id_safe",
      "rule": "safe_identifier",
      "field": "video_id"
    },
    {
      "id": "track_ge0",
      "rule": "int_ge",
      "field": "track_id",
      "value": 0
    },
    {
      "id": "first_le_last",
      "rule": "int_le_pair",
      "left": "first_frame_index",
      "right": "last_frame_index"
    },
    {
      "id": "counts_ge0",
      "rule": "int_ge",
      "fields": [
        "observation_count",
        "observed_count",
        "predicted_count"
      ],
      "value": 0
    },
    {
      "id": "count_consistency",
      "rule": "track_summary_counts"
    },
    {
      "id": "conf_unit_or_null",
      "rule": "float_unit_interval_or_null",
      "fields": [
        "mean_confidence",
        "max_confidence"
      ]
    },
    {
      "id": "term_nonempty",
      "rule": "nonempty_string",
      "field": "termination_reason"
    },
    {
      "id": "quality_no_null_items",
      "rule": "list_no_null_items",
      "field": "quality_flags"
    }
  ],
  "table_metadata": {}
}
