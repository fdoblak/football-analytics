      "nullable": false
    },
    {
      "name": "source_sha256",
      "type": "string",
      "nullable": false
    },
    {
      "name": "container",
      "type": "string",
      "nullable": false
    },
    {
      "name": "codec",
      "type": "string",
      "nullable": true
    },
    {
      "name": "width_px",
      "type": "int32",
      "nullable": false
    },
    {
      "name": "height_px",
      "type": "int32",
      "nullable": false
    },
    {
      "name": "fps_numerator",
      "type": "int32",
      "nullable": false
    },
    {
      "name": "fps_denominator",
      "type": "int32",
      "nullable": false
    },
    {
      "name": "time_base_numerator",
      "type": "int32",
      "nullable": false
    },
    {
      "name": "time_base_denominator",
      "type": "int32",
      "nullable": false
    },
    {
      "name": "frame_count",
      "type": "int64",
      "nullable": true
    },
    {
      "name": "duration_us",
      "type": "int64",
      "nullable": true
    },
    {
      "name": "has_audio",
      "type": "bool",
      "nullable": true
    },
    {
      "name": "source_ref",
      "type": "string",
      "nullable": true
    }
