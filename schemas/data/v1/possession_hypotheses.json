{
  "contract_name": "possession_hypotheses",
  "version": 1,
  "description": "Stage 10A possession hypotheses. Automatic baseline may produce at most provisional; confirmed requires strong multi-evidence or scoped manual review. Not pass/dribble/duel/box-touch events.",
  "fields": [
    {"name": "run_id", "type": "string", "nullable": false},
    {"name": "video_id", "type": "string", "nullable": false},
    {"name": "hypothesis_id", "type": "string", "nullable": false},
    {"name": "owner_human_track_id", "type": "int64", "nullable": true},
    {"name": "owner_team_id", "type": "string", "nullable": true},
    {"name": "ownership_kind", "type": "string", "nullable": false},
    {"name": "target_relationship", "type": "string", "nullable": false},
    {"name": "start_time_us", "type": "int64", "nullable": false},
    {"name": "end_time_us", "type": "int64", "nullable": false},
    {"name": "possession_state", "type": "string", "nullable": false},
    {"name": "contested_participant_track_ids", "type": "list", "nullable": false, "value_type": "int64"},
    {"name": "evidence_refs", "type": "list", "nullable": false, "value_type": "string"},
    {"name": "contact_candidate_ids", "type": "list", "nullable": false, "value_type": "string"},
    {"name": "proximity_ids", "type": "list", "nullable": false, "value_type": "string"},
    {"name": "observed_coverage_ratio", "type": "float32", "nullable": true},
    {"name": "derived_coverage_ratio", "type": "float32", "nullable": true},
    {"name": "uncertainty", "type": "float32", "nullable": true},
    {"name": "termination_reason", "type": "string", "nullable": false},
    {"name": "transition_from_hypothesis_id", "type": "string", "nullable": true},
    {"name": "automatic_ceiling", "type": "string", "nullable": false},
    {"name": "implies_completed_pass", "type": "bool", "nullable": false},
    {"name": "implies_dribble_or_take_on", "type": "bool", "nullable": false},
    {"name": "implies_duel_or_aerial", "type": "bool", "nullable": false},
    {"name": "implies_box_touch", "type": "bool", "nullable": false},
    {"name": "implies_turnover", "type": "bool", "nullable": false},
    {"name": "penalty_area_presence_only", "type": "bool", "nullable": false},
    {"name": "manual_review_required", "type": "bool", "nullable": false},
    {"name": "review_status", "type": "string", "nullable": false},
    {"name": "decision_log_json", "type": "string", "nullable": true},
    {"name": "reason_codes", "type": "list", "nullable": false, "value_type": "string"},
    {"name": "quality_flags", "type": "list", "nullable": false, "value_type": "string"},
    {"name": "policy_fingerprint", "type": "string", "nullable": false},
    {"name": "provenance_json", "type": "string", "nullable": true},
    {"name": "contract_version", "type": "int32", "nullable": false}
  ],
  "primary_key": ["run_id", "video_id", "hypothesis_id"],
  "foreign_keys": [],
  "partition_by": ["run_id", "video_id"],
  "sort_by": ["run_id", "video_id", "start_time_us", "hypothesis_id"],
  "semantic_rules": [
    {"id": "run_id_format", "rule": "run_id_stage2b"},
    {"id": "video_id_safe", "rule": "safe_identifier", "field": "video_id"},
    {"id": "hypothesis_safe", "rule": "safe_identifier", "field": "hypothesis_id"},
    {"id": "owner_track_ge0_or_null", "rule": "int_ge_or_null", "field": "owner_human_track_id", "value": 0},
    {"id": "start_ge0", "rule": "int_ge", "field": "start_time_us", "value": 0},
    {"id": "end_ge0", "rule": "int_ge", "field": "end_time_us", "value": 0},
    {"id": "ownership_enum", "rule": "enum", "field": "ownership_kind", "values": ["human_track", "anonymous_team", "unknown", "none"]},
    {"id": "target_rel_enum", "rule": "enum", "field": "target_relationship", "values": ["confirmed_target", "candidate_target", "non_target", "anonymous", "unknown"]},
    {"id": "possession_state_enum", "rule": "enum", "field": "possession_state", "values": ["candidate", "provisional", "confirmed", "contested", "unknown", "not_evaluable", "rejected"]},
    {"id": "termination_enum", "rule": "enum", "field": "termination_reason", "values": ["none", "shot_cut", "replay", "non_playable", "ball_loss", "hard_gap", "track_termination", "owner_transition", "contested", "manual_revocation", "unknown"]},
    {"id": "ceiling_enum", "rule": "enum", "field": "automatic_ceiling", "values": ["candidate", "provisional"]},
    {"id": "review_enum", "rule": "enum", "field": "review_status", "values": ["unreviewed", "reviewed", "rejected", "not_required", "revoked"]},
    {"id": "contested_no_null", "rule": "list_no_null_items", "field": "contested_participant_track_ids"},
    {"id": "evidence_no_null", "rule": "list_no_null_items", "field": "evidence_refs"},
    {"id": "contact_no_null", "rule": "list_no_null_items", "field": "contact_candidate_ids"},
    {"id": "prox_no_null", "rule": "list_no_null_items", "field": "proximity_ids"},
    {"id": "reason_no_null", "rule": "list_no_null_items", "field": "reason_codes"},
    {"id": "quality_no_null", "rule": "list_no_null_items", "field": "quality_flags"},
    {"id": "contract_version_ge1", "rule": "int_ge", "field": "contract_version", "value": 1}
  ],
  "table_metadata": {
    "stage": "10A",
    "interval_semantics": "half_open_start_end",
    "time_base": "video_time_us",
    "hard_gap_no_carry": "true",
    "automatic_confirmed_forbidden": "true",
    "append_only_decisions": "true",
    "possession_is_not_event": "true"
  }
}
