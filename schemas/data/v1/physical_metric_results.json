{
  "contract_name": "physical_metric_results",
  "version": 1,
  "description": "Stage 9A physical metric result contract rows. Values may be null/not_evaluable; Stage 9A does not compute real metrics.",
  "fields": [
    {"name": "run_id", "type": "string", "nullable": false},
    {"name": "video_id", "type": "string", "nullable": false},
    {"name": "target_player_id", "type": "string", "nullable": false},
    {"name": "metric_result_id", "type": "string", "nullable": false},
    {"name": "metric_name", "type": "string", "nullable": false},
    {"name": "metric_version", "type": "int32", "nullable": false},
    {"name": "time_scope_start_us", "type": "int64", "nullable": false},
    {"name": "time_scope_end_us", "type": "int64", "nullable": false},
    {"name": "value", "type": "float64", "nullable": true},
    {"name": "unit", "type": "string", "nullable": false},
    {"name": "status", "type": "string", "nullable": false},
    {"name": "coverage_ratio", "type": "float32", "nullable": true},
    {"name": "confidence", "type": "float32", "nullable": true},
    {"name": "uncertainty", "type": "float32", "nullable": true},
    {"name": "included_sample_count", "type": "int64", "nullable": false},
    {"name": "excluded_sample_count", "type": "int64", "nullable": false},
    {"name": "included_duration_us", "type": "int64", "nullable": false},
    {"name": "excluded_duration_us", "type": "int64", "nullable": false},
    {"name": "sample_layer", "type": "string", "nullable": false},
    {"name": "trajectory_segment_ids", "type": "list", "nullable": false, "value_type": "string"},
    {"name": "evidence_ids", "type": "list", "nullable": false, "value_type": "string"},
    {"name": "config_fingerprint", "type": "string", "nullable": false},
    {"name": "trajectory_artifact_fingerprint", "type": "string", "nullable": true},
    {"name": "calibration_artifact_fingerprint", "type": "string", "nullable": true},
    {"name": "identity_artifact_fingerprint", "type": "string", "nullable": true},
    {"name": "warning_codes", "type": "list", "nullable": false, "value_type": "string"},
    {"name": "reason_codes", "type": "list", "nullable": false, "value_type": "string"},
    {"name": "review_status", "type": "string", "nullable": false},
    {"name": "producer", "type": "string", "nullable": false},
    {"name": "producer_version", "type": "string", "nullable": false},
    {"name": "provenance_json", "type": "string", "nullable": true},
    {"name": "contract_version", "type": "int32", "nullable": false}
  ],
  "primary_key": ["run_id", "video_id", "target_player_id", "metric_result_id"],
  "foreign_keys": [],
  "partition_by": ["run_id", "video_id"],
  "sort_by": ["run_id", "video_id", "target_player_id", "metric_name", "metric_result_id"],
  "semantic_rules": [
    {"id": "run_id_format", "rule": "run_id_stage2b"},
    {"id": "video_id_safe", "rule": "safe_identifier", "field": "video_id"},
    {"id": "target_safe", "rule": "safe_identifier", "field": "target_player_id"},
    {"id": "result_safe", "rule": "safe_identifier", "field": "metric_result_id"},
    {"id": "metric_safe", "rule": "safe_identifier", "field": "metric_name"},
    {"id": "metric_version_ge1", "rule": "int_ge", "field": "metric_version", "value": 1},
    {"id": "start_ge0", "rule": "int_ge", "field": "time_scope_start_us", "value": 0},
    {"id": "end_ge0", "rule": "int_ge", "field": "time_scope_end_us", "value": 0},
    {"id": "included_ge0", "rule": "int_ge", "field": "included_sample_count", "value": 0},
    {"id": "excluded_ge0", "rule": "int_ge", "field": "excluded_sample_count", "value": 0},
    {"id": "inc_dur_ge0", "rule": "int_ge", "field": "included_duration_us", "value": 0},
    {"id": "exc_dur_ge0", "rule": "int_ge", "field": "excluded_duration_us", "value": 0},
    {
      "id": "status_enum",
      "rule": "enum",
      "field": "status",
      "values": ["computed", "partial", "not_evaluable", "insufficient_coverage", "failed", "contract_stub"]
    },
    {
      "id": "unit_enum",
      "rule": "enum",
      "field": "unit",
      "values": ["m", "m_s", "km_h", "s", "count", "ratio", "grid", "none", "unknown"]
    },
    {
      "id": "sample_layer_enum",
      "rule": "enum",
      "field": "sample_layer",
      "values": ["raw_observed", "filtered", "resampled", "mixed", "none"]
    },
    {
      "id": "review_status_enum",
      "rule": "enum",
      "field": "review_status",
      "values": ["unreviewed", "reviewed", "rejected", "not_required"]
    },
    {"id": "coverage_ge0_or_null", "rule": "float_ge_or_null", "field": "coverage_ratio", "value": 0},
    {"id": "confidence_ge0_or_null", "rule": "float_ge_or_null", "field": "confidence", "value": 0},
    {"id": "uncertainty_ge0_or_null", "rule": "float_ge_or_null", "field": "uncertainty", "value": 0},
    {"id": "seg_no_null", "rule": "list_no_null_items", "field": "trajectory_segment_ids"},
    {"id": "evidence_no_null", "rule": "list_no_null_items", "field": "evidence_ids"},
    {"id": "warning_no_null", "rule": "list_no_null_items", "field": "warning_codes"},
    {"id": "reason_no_null", "rule": "list_no_null_items", "field": "reason_codes"},
    {"id": "contract_version_ge1", "rule": "int_ge", "field": "contract_version", "value": 1}
  ],
  "table_metadata": {
    "stage": "9A",
    "zero_vs_null_vs_not_evaluable": "distinct",
    "no_real_metric_computation": "true",
    "not_official_opta": "true"
  }
}
