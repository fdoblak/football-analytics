    {"name": "end_x_m", "type": "float32", "nullable": true},
    {"name": "end_y_m", "type": "float32", "nullable": true},
    {"name": "pass_distance_m", "type": "float32", "nullable": true},
    {"name": "start_zone_neutral", "type": "string", "nullable": false},
    {"name": "end_zone_neutral", "type": "string", "nullable": false},
    {"name": "candidate_state", "type": "string", "nullable": false},
    {"name": "target_relationship", "type": "string", "nullable": false},
    {"name": "possession_hypothesis_id", "type": "string", "nullable": true},
    {"name": "contact_candidate_ids", "type": "list", "nullable": false, "value_type": "string"},
    {"name": "evidence_refs", "type": "list", "nullable": false, "value_type": "string"},
    {"name": "cut_or_replay", "type": "bool", "nullable": false},
    {"name": "hard_gap", "type": "bool", "nullable": false},
    {"name": "owner_change_alone", "type": "bool", "nullable": false},
    {"name": "implies_completed_pass", "type": "bool", "nullable": false},
    {"name": "playability_status", "type": "string", "nullable": false},
    {"name": "calibration_status", "type": "string", "nullable": false},
    {"name": "automatic_ceiling", "type": "string", "nullable": false},
    {"name": "review_status", "type": "string", "nullable": false},
    {"name": "manual_review_required", "type": "bool", "nullable": false},
    {"name": "uncertainty", "type": "float32", "nullable": true},
    {"name": "reason_codes", "type": "list", "nullable": false, "value_type": "string"},
    {"name": "quality_flags", "type": "list", "nullable": false, "value_type": "string"},
    {"name": "metric_origin", "type": "string", "nullable": false},
    {"name": "definition_style", "type": "string", "nullable": false},
    {"name": "policy_fingerprint", "type": "string", "nullable": false},
    {"name": "provenance_json", "type": "string", "nullable": true},
    {"name": "contract_version", "type": "int32", "nullable": false}
  ],
  "primary_key": ["run_id", "video_id", "pass_candidate_id"],
  "foreign_keys": [],
  "partition_by": ["run_id", "video_id"],
  "sort_by": ["run_id", "video_id", "start_time_us", "pass_candidate_id"],
  "semantic_rules": [
    {"id": "run_id_format", "rule": "run_id_stage2b"},
    {"id": "video_id_safe", "rule": "safe_identifier", "field": "video_id"},
    {"id": "pass_cand_safe", "rule": "safe_identifier", "field": "pass_candidate_id"},
    {"id": "passer_ge0", "rule": "int_ge", "field": "passer_human_track_id", "value": 0},
    {"id": "receiver_ge0_or_null", "rule": "int_ge_or_null", "field": "intended_receiver_track_id", "value": 0},
    {"id": "start_ge0", "rule": "int_ge", "field": "start_time_us", "value": 0},
    {"id": "end_ge0", "rule": "int_ge", "field": "end_time_us", "value": 0},
    {"id": "start_zone_enum", "rule": "enum", "field": "start_zone_neutral", "values": ["goal_a", "middle", "goal_b", "unknown", "not_evaluable"]},
    {"id": "end_zone_enum", "rule": "enum", "field": "end_zone_neutral", "values": ["goal_a", "middle", "goal_b", "unknown", "not_evaluable"]},
    {"id": "candidate_state_enum", "rule": "enum", "field": "candidate_state", "values": ["candidate", "provisional", "confirmed", "contested", "unknown", "not_evaluable", "rejected"]},
    {"id": "target_rel_enum", "rule": "enum", "field": "target_relationship", "values": ["confirmed_target", "candidate_target", "non_target", "anonymous", "unknown"]},
    {"id": "playability_enum", "rule": "enum", "field": "playability_status", "values": ["playable", "replay", "non_playable", "unknown"]},
    {"id": "calibration_enum", "rule": "enum", "field": "calibration_status", "values": ["valid", "invalid", "unknown"]},
    {"id": "ceiling_enum", "rule": "enum", "field": "automatic_ceiling", "values": ["candidate", "provisional"]},
    {"id": "review_enum", "rule": "enum", "field": "review_status", "values": ["unreviewed", "reviewed", "rejected", "not_required", "revoked"]},
    {"id": "metric_origin_enum", "rule": "enum", "field": "metric_origin", "values": ["project_generated"]},
    {"id": "definition_style_enum", "rule": "enum", "field": "definition_style", "values": ["opta_style_metric_definition"]},
    {"id": "contact_no_null", "rule": "list_no_null_items", "field": "contact_candidate_ids"},
    {"id": "evidence_no_null", "rule": "list_no_null_items", "field": "evidence_refs"},
    {"id": "reason_no_null", "rule": "list_no_null_items", "field": "reason_codes"},
    {"id": "quality_no_null", "rule": "list_no_null_items", "field": "quality_flags"},
    {"id": "contract_version_ge1", "rule": "int_ge", "field": "contract_version", "value": 1}
  ],
  "table_metadata": {
    "stage": "11A",
    "owner_change_alone_not_completed_pass": "true",
    "cut_replay_gap_no_pass": "true",
    "automatic_confirmed_forbidden": "true",
    "metric_origin": "project_generated",
    "definition_style": "opta_style_metric_definition",
    "interval_semantics": "half_open_start_end",
    "time_base": "video_time_us"
  }
}
