{
  "contract_name": "calibration_features",
  "version": 1,
  "description": "Stage 8A synthetic/future pitch keypoint and line observations for calibration. No SV_kp/SV_lines inference in this stage.",
  "fields": [
    {"name": "run_id", "type": "string", "nullable": false},
    {"name": "video_id", "type": "string", "nullable": false},
    {"name": "frame_index", "type": "int64", "nullable": false},
    {"name": "video_time_us", "type": "int64", "nullable": false},
    {"name": "feature_id", "type": "string", "nullable": false},
    {"name": "feature_type", "type": "string", "nullable": false},
    {"name": "canonical_pitch_feature_id", "type": "string", "nullable": true},
    {"name": "image_x", "type": "float64", "nullable": true},
    {"name": "image_y", "type": "float64", "nullable": true},
    {"name": "line_x1", "type": "float64", "nullable": true},
    {"name": "line_y1", "type": "float64", "nullable": true},
    {"name": "line_x2", "type": "float64", "nullable": true},
    {"name": "line_y2", "type": "float64", "nullable": true},
    {"name": "coordinate_frame_id", "type": "string", "nullable": false},
    {"name": "score", "type": "float32", "nullable": true},
    {"name": "confidence", "type": "float32", "nullable": true},
    {"name": "source", "type": "string", "nullable": false},
    {"name": "model_ref", "type": "string", "nullable": true},
    {"name": "suitability", "type": "string", "nullable": false},
    {"name": "status", "type": "string", "nullable": false},
    {"name": "manual_review_required", "type": "bool", "nullable": false},
    {"name": "reason_codes", "type": "list", "nullable": false, "value_type": "string"},
    {"name": "quality_flags", "type": "list", "nullable": false, "value_type": "string"},
    {"name": "provenance_json", "type": "string", "nullable": true},
    {"name": "contract_version", "type": "int32", "nullable": false}
  ],
  "primary_key": ["run_id", "video_id", "frame_index", "feature_id"],
  "foreign_keys": [
    {
      "fields": ["run_id", "video_id", "frame_index"],
      "ref_contract": "frames",
      "ref_fields": ["run_id", "video_id", "frame_index"],
      "ref_version": 1
    }
  ],
  "partition_by": ["run_id", "video_id"],
  "sort_by": ["run_id", "video_id", "frame_index", "feature_id"],
  "semantic_rules": [
    {"id": "run_id_format", "rule": "run_id_stage2b"},
    {"id": "video_id_safe", "rule": "safe_identifier", "field": "video_id"},
    {"id": "feature_id_safe", "rule": "safe_identifier", "field": "feature_id"},
    {"id": "frame_ge0", "rule": "int_ge", "field": "frame_index", "value": 0},
    {"id": "time_ge0", "rule": "int_ge", "field": "video_time_us", "value": 0},
    {
      "id": "feature_type_enum",
      "rule": "enum",
      "field": "feature_type",
      "values": ["keypoint", "line", "line_intersection", "unknown"]
    },
    {
      "id": "suitability_enum",
      "rule": "enum",
      "field": "suitability",
      "values": ["suitable", "marginal", "unsuitable", "unknown"]
    },
    {
      "id": "status_enum",
      "rule": "enum",
      "field": "status",
      "values": ["detected", "matched", "unmatched", "rejected", "unknown"]
    },
    {
      "id": "coord_frame_enum",
      "rule": "enum",
      "field": "coordinate_frame_id",
      "values": ["source_image", "normalized_image", "model_space", "canonical_pitch", "attack_relative"]
    },
    {"id": "score_unit_or_null", "rule": "float_unit_interval_or_null", "field": "score"},
    {"id": "conf_unit_or_null", "rule": "float_unit_interval_or_null", "field": "confidence"},
    {"id": "reason_no_null", "rule": "list_no_null_items", "field": "reason_codes"},
    {"id": "quality_no_null", "rule": "list_no_null_items", "field": "quality_flags"},
    {"id": "contract_version_ge1", "rule": "int_ge", "field": "contract_version", "value": 1}
  ],
  "table_metadata": {
    "stage": "8A",
    "synthetic_only": "true",
    "no_sv_inference": "true"
  }
}
