{
  "contract_name": "track_observations",
  "version": 1,
  "description": "Per-frame track observations linked to optional detections.",
  "fields": [
    {
      "name": "run_id",
      "type": "string",
      "nullable": false
    },
    {
      "name": "video_id",
      "type": "string",
      "nullable": false
    },
    {
      "name": "frame_index",
      "type": "int64",
      "nullable": false
    },
    {
      "name": "track_id",
      "type": "int64",
      "nullable": false
    },
    {
      "name": "detection_id",
      "type": "int64",
      "nullable": true
    },
    {
      "name": "class_id",
      "type": "int16",
      "nullable": false
    },
    {
      "name": "confidence",
      "type": "float32",
      "nullable": true
    },
    {
      "name": "bbox_x1",
      "type": "float32",
      "nullable": false
    },
    {
      "name": "bbox_y1",
      "type": "float32",
      "nullable": false
    },
    {
      "name": "bbox_x2",
      "type": "float32",
      "nullable": false
    },
    {
      "name": "bbox_y2",
      "type": "float32",
      "nullable": false
    },
    {
      "name": "observation_state",
      "type": "string",
      "nullable": false
    },
    {
      "name": "model_id",
      "type": "string",
      "nullable": false
    },
    {
      "name": "quality_flags",
      "type": "list",
      "nullable": false,
      "value_type": "string"
    }
  ],
  "primary_key": [
    "run_id",
    "video_id",
    "frame_index",
    "track_id"
  ],
  "foreign_keys": [
    {
      "fields": [
        "run_id",
        "video_id",
        "frame_index"
      ],
      "ref_contract": "frames",
      "ref_fields": [
        "run_id",
        "video_id",
        "frame_index"
      ],
      "ref_version": 1
    },
    {
      "fields": [
        "run_id",
        "video_id",
        "frame_index",
        "detection_id"
      ],
      "ref_contract": "detections",
      "ref_fields": [
        "run_id",
        "video_id",
        "frame_index",
        "detection_id"
      ],
      "ref_version": 1,
      "nullable": true
    }
  ],
  "partition_by": [
    "run_id",
    "video_id"
  ],
  "sort_by": [
    "run_id",
    "video_id",
    "frame_index",
    "track_id"
  ],
  "semantic_rules": [
    {
      "id": "run_id_format",
      "rule": "run_id_stage2b"
    },
    {
      "id": "video_id_safe",
      "rule": "safe_identifier",
      "field": "video_id"
    },
    {
      "id": "frame_ge0",
      "rule": "int_ge",
      "field": "frame_index",
      "value": 0
    },
    {
      "id": "track_ge0",
      "rule": "int_ge",
      "field": "track_id",
      "value": 0
    },
    {
      "id": "conf_unit_or_null",
      "rule": "float_unit_interval_or_null",
      "field": "confidence"
    },
    {
      "id": "bbox_xyxy",
      "rule": "bbox_xyxy_half_open"
    },
    {
      "id": "state_enum",
      "rule": "enum",
      "field": "observation_state",
      "values": [
        "observed",
        "predicted",
        "interpolated"
      ]
    },
    {
      "id": "model_id_safe",
      "rule": "safe_identifier",
      "field": "model_id"
    },
    {
      "id": "quality_no_null_items",
      "rule": "list_no_null_items",
      "field": "quality_flags"
    }
  ],
  "table_metadata": {
    "coordinate_space": "image_pixels",
    "bbox_format": "xyxy",
    "bbox_bounds": "half-open"
  }
}
