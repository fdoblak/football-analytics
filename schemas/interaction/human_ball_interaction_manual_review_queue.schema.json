{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://football-analytics.local/schemas/interaction/human_ball_interaction_manual_review_queue.schema.json",
  "title": "Human-ball interaction manual review queue (Stage 10A)",
  "description": "Append-only review queue entries for possession/contact confirmation or revocation.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "queue_id",
    "run_id",
    "video_id",
    "entries",
    "created_at_utc"
  ],
  "properties": {
    "schema_version": { "type": "integer", "const": 1 },
    "queue_id": { "type": "string", "pattern": "^[a-z][a-z0-9_]{1,63}$" },
    "run_id": { "type": "string", "minLength": 8 },
    "video_id": { "type": "string", "minLength": 1 },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "entry_id",
          "subject_type",
          "subject_id",
          "requested_action",
          "current_state",
          "append_only",
          "created_at_utc"
        ],
        "properties": {
          "entry_id": { "type": "string", "minLength": 1 },
          "subject_type": {
            "type": "string",
            "enum": ["proximity", "contact_candidate", "possession_hypothesis"]
          },
          "subject_id": { "type": "string", "minLength": 1 },
          "requested_action": {
            "type": "string",
            "enum": ["confirm", "reject", "revoke", "mark_contested", "request_more_evidence"]
          },
          "current_state": {
            "type": "string",
            "enum": ["candidate", "provisional", "confirmed", "contested", "unknown", "not_evaluable", "rejected"]
          },
          "append_only": { "type": "boolean", "const": true },
          "notes": { "type": "string" },
          "created_at_utc": { "type": "string", "minLength": 10 }
        }
      }
    },
    "created_at_utc": { "type": "string", "minLength": 10 }
  }
}
