{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://football-analytics.local/schemas/passing/attack_direction_evidence.schema.json",
  "title": "Attack direction evidence (Stage 11)",
  "description": "Manual/config evidence only. Conflict yields unknown. Never invent.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "video_id",
    "attack_direction",
    "evidence_source",
    "evidence_refs",
    "conflict",
    "invented",
    "created_at_utc"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 8
    },
    "video_id": {
      "type": "string",
      "minLength": 1
    },
    "attack_direction": {
      "type": "string",
      "enum": [
        "toward_goal_a",
        "toward_goal_b",
        "unknown"
      ]
    },
    "evidence_source": {
      "type": "string",
      "enum": [
        "manual",
        "config",
        "none",
        "conflict"
      ]
    },
    "evidence_refs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "conflict": {
      "type": "boolean"
    },
    "invented": {
      "type": "boolean",
      "const": false
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    },
    "created_at_utc": {
      "type": "string",
      "minLength": 10
    }
  }
}
