{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://football-analytics.local/schemas/passing/passing_quality.schema.json",
  "title": "Passing quality / coverage (Stage 11A)",
  "description": "Coverage and quality summary for passing contracts.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "run_id",
    "video_id",
    "coverage",
    "quality_flags",
    "not_evaluable_reasons",
    "created_at_utc"
  ],
  "properties": {
    "schema_version": {
      "type": "integer",
      "const": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 8
    },
    "video_id": {
      "type": "string",
      "minLength": 1
    },
    "passing_policy_fingerprint": {
      "type": [
        "string",
        "null"
      ]
    },
    "coverage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "target_confirmed_us",
        "possession_or_contact_us",
        "calibration_valid_us",
        "playable_us",
        "attack_direction_resolved_us",
        "not_observed_us"
      ],
      "properties": {
        "target_confirmed_us": {
          "type": "integer",
          "minimum": 0
        },
        "possession_or_contact_us": {
          "type": "integer",
          "minimum": 0
        },
        "calibration_valid_us": {
          "type": "integer",
          "minimum": 0
        },
        "playable_us": {
          "type": "integer",
          "minimum": 0
        },
        "attack_direction_resolved_us": {
          "type": "integer",
          "minimum": 0
        },
        "not_observed_us": {
          "type": "integer",
          "minimum": 0
        },
        "joint_coverage_ratio": {
          "type": [
            "number",
            "null"
          ]
        },
        "owner_change_alone_is_not_completed_pass": {
          "type": "boolean",
          "const": true
        },
        "penalty_presence_is_not_box_touch": {
          "type": "boolean"
        },
        "attack_direction_unknown_blocks_directional": {
          "type": "boolean"
        }
      }
    },
    "quality_flags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "not_evaluable_reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "created_at_utc": {
      "type": "string",
      "minLength": 10
    }
  }
}
